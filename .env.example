# ENGRAM Environment Configuration
# Copy this file to .env and update values as needed

# Node Environment
NODE_ENV=development

# Application
PORT=3000
MCP_TRANSPORT=streamable-http
# MCP transport mode for local MCP endpoint testing
# PostgreSQL Database
POSTGRES_DB=engram
POSTGRES_USER=engram
POSTGRES_PASSWORD=dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://engram:dev_password@localhost:5432/engram


# Vector store (pgvector — vectors live in Postgres; no separate service)
# Optional strict pin for embedding dimensionality. Leave unset: dimensions are
# inferred from the embedding model (nomic-embed-text = 768, OpenAI small = 1536).
# VECTOR_DIMENSIONS=768

# ─── Embeddings (local-first) ────────────────────────────────────────────────
# Default: a local Ollama server — no API key, no per-token cost.
#   Install: https://ollama.com/download   then: ollama pull nomic-embed-text
#   (or run the bundled container: docker compose --profile ollama up -d)
# Providers: ollama (default) | openai | local (hash, testing) | disabled
EMBEDDING_PROVIDER=ollama
# Model id; defaults per provider (ollama→nomic-embed-text, openai→text-embedding-3-small).
# Changing it later requires a full reindex with recreate+regenerate.
# EMBEDDING_MODEL=nomic-embed-text
# Ollama server base URL (default http://localhost:11434)
# OLLAMA_URL=http://localhost:11434
# Only needed for EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Optional pgvector HNSW tuning
# PGVECTOR_HNSW_M=16
# PGVECTOR_HNSW_EF_CONSTRUCTION=64
# PGVECTOR_HNSW_EF_SEARCH=100

# ─── Authentication & Multi-tenancy (Epic E4) ───────────────────────────────
# JWT signing secret for interactive sessions. MUST be >= 32 chars and is
# REQUIRED when AUTH_REQUIRED=true. Keep this out of logs and source control.
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
# JWT lifetime: a duration string (7d, 24h, 30m, 3600s) or a plain number of seconds.
JWT_EXPIRES_IN=7d

# Enforce authentication on the /mcp endpoint. When true, every tool call must
# carry a valid JWT (Authorization: Bearer <jwt>) or API key (X-API-Key /
# Authorization: Bearer eng_...), and the acting userId is taken from that
# credential — the userId in tool input is ignored. Default false keeps the
# existing trusted-caller behaviour. Only enforced over the streamable-http transport.
# AUTH_REQUIRED=false

# A multi-tenant (enterprise) streamable-http server WITHOUT AUTH_REQUIRED refuses
# to boot in EVERY NODE_ENV unless you explicitly acknowledge the trusted-network
# posture with this flag. Prefer AUTH_REQUIRED=true (see docs/security/agent-keys.md).
# ALLOW_UNAUTHENTICATED_HTTP=false

# OAuth login (enterprise). Set a provider's id AND secret to enable it.
# Callback URLs are <OAUTH_REDIRECT_BASE_URL>/auth/<provider>/callback —
# register exactly those with the provider.
# OAUTH_REDIRECT_BASE_URL=http://localhost:3000
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Rate limiting (#132) ────────────────────────────────────────────────────
# Postgres-backed per-tenant / per-key / per-IP rate limiting (standard profile only).
# Limits are metered in work units, not raw requests: most tool calls cost one
# unit, but ingest_conversation costs one unit per 10 KB chunk it stores (#204),
# so bulk ingests draw down the budget proportionally to the work they cause.
# RATE_LIMIT_ENABLED=false
# RATE_LIMIT_WINDOW_SEC=60          # window length; *_RPM values are per this window
# RATE_LIMIT_USER_RPM=120          # per authenticated user
# RATE_LIMIT_ORG_RPM=6000          # aggregated per organization
# RATE_LIMIT_IP_RPM=60             # per unauthenticated client IP
# Per-tool overrides as JSON, e.g. stricter limit on expensive admin tools, or
# a dedicated chunk budget for bulk ingestion:
# RATE_LIMIT_TOOL_OVERRIDES={"reindex_memories":{"limit":2,"windowSeconds":3600},"ingest_conversation":{"limit":500,"windowSeconds":3600}}

# MCP maintenance authorization token (required for reindex + consolidation admin tools)
MCP_ADMIN_TOKEN=replace-with-a-long-random-token

# STM→LTM consolidation policy
# Number of accesses before a short-term memory is promoted to long-term (default: 3)
# STM_CONSOLIDATION_ACCESS_THRESHOLD=3
# How often the consolidation job runs in milliseconds; set to 0 to disable (default: 300000)
# STM_CONSOLIDATION_INTERVAL_MS=300000
# How often expired short-term rows are bulk-deleted (hygiene; reads always filter on expiry); 0 disables (default: 600000)
# STM_SWEEP_INTERVAL_MS=600000
# How often expired auth KV rows and lapsed rate-limit counters are swept; 0 disables (default: 900000)
# AUTH_STORE_SWEEP_INTERVAL_MS=900000

# LTM lifecycle: decay / staleness, dedup, contradiction, importance
# How often the decay/staleness job scans the corpus in ms; set to 0 to disable (default: 86400000)
# MEMORY_DECAY_INTERVAL_MS=86400000
# Rows scanned per decay batch (default: 100)
# MEMORY_DECAY_BATCH_SIZE=100
# Importance score at/below which a memory is marked stale (default: 0.3)
# MEMORY_DECAY_STALE_SCORE_THRESHOLD=0.3
# Importance score below which an old, unpinned memory is pruned (default: 0.15)
# MEMORY_DECAY_PRUNE_SCORE_THRESHOLD=0.15
# Minimum age in days before a low-importance memory is prune-eligible (default: 30)
# MEMORY_DECAY_PRUNE_OLDER_THAN_DAYS=30
# Cosine similarity at/above which a write collapses into an existing row (default: 0.97)
# MEMORY_DUPLICATE_THRESHOLD=0.97
# Corpus consolidation (near-duplicate clustering, consolidate_corpus tool): lower bound of the
# merge band [merge, MEMORY_DUPLICATE_THRESHOLD) — must stay strictly below the duplicate
# threshold (validated at boot). (default: 0.85)
# MEMORY_CONSOLIDATION_MERGE_THRESHOLD=0.85
# How often the corpus-consolidation job runs in ms. Default 0 = DISABLED (review gate):
# scheduled passes merge WITHOUT review, so inspect a consolidate_corpus dry run first,
# then opt in explicitly by setting an interval (e.g. 86400000 = daily).
# MEMORY_CONSOLIDATION_INTERVAL_MS=0
# Contradiction similarity band, lower bound (default: 0.8) and exclusive upper bound (default: 0.97)
# MEMORY_CONTRADICTION_THRESHOLD=0.8
# MEMORY_CONTRADICTION_THRESHOLD_MAX=0.97
# Contradiction policy: 'flag' keeps BOTH rows visible and marks them contradicted for review;
# 'supersede' hides the older row from default recall (latest-wins). (default: flag)
# MEMORY_CONTRADICTION_POLICY=flag
# Half-life in days for the recency component of importance scoring (default: 14)
# MEMORY_IMPORTANCE_HALF_LIFE_DAYS=14

# Absolute directory import_agent_memory paths must resolve into (symlinks resolved); default: server home directory
# IMPORT_ALLOWED_ROOT=/srv/engram/imports

# Logging
LOG_LEVEL=debug

# OpenTelemetry tracing (optional — omit to disable tracing entirely)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=engram-mcp-server
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production

# Backup and retention
# BACKUP_DIR=/var/backups/engram        # directory for backup archives
# BACKUP_RETENTION_DAYS=30              # how many days to keep daily backups
# BACKUP_RETENTION_WEEKLY=12            # how many weeks to keep weekly backups

# ─────────────────────────────────────────────────────────────────────────────
# Admin dashboard (apps/web) — the tRPC + Next.js operator console
# ─────────────────────────────────────────────────────────────────────────────
# The dashboard reads Postgres directly for listing and analytics, and proxies
# writes + semantic recall + health to the MCP server below. It runs on port
# 3001 by default (the MCP server uses 3000).
#
# The dashboard never writes to Postgres, so give it a read-only role instead of
# the full-privilege DATABASE_URL (defense-in-depth). docker/postgres provisions
# an `engram_readonly` role on first DB init; point WEB_DATABASE_URL at it.
# WEB_DB_READONLY_PASSWORD (consumed by the Postgres container's init script) is
# required by docker-compose.prod.yml — set it to a strong value and reuse it in
# WEB_DATABASE_URL. When WEB_DATABASE_URL is unset the dashboard falls back to
# DATABASE_URL.
# WEB_DB_READONLY_PASSWORD=dev_password_readonly
# WEB_DATABASE_URL=postgresql://engram_readonly:dev_password_readonly@localhost:5432/engram

# Base URL of a running MCP server. Enables semantic search, edit/delete, and
# the live health view. Omit it and the console still works read-only over
# Postgres (keyword search, no writes).
# ENGRAM_MCP_URL=http://localhost:3000
# Service API key used for MCP writes/recall when the MCP server has
# AUTH_REQUIRED=true. Mint one with create_api_key. To manage EVERY data owner
# from the console the key must carry the `admin` scope (delegated mode); a
# key with only memories:read/write/delete is pinned to its own tenant, so
# writes and semantic search work for that single owner only (the console's
# Settings page surfaces this limitation).
# ENGRAM_API_KEY=eng_...

# NextAuth.js v5 (Auth.js). AUTH_SECRET is required at runtime — generate with
# `openssl rand -base64 32` (or `npx auth secret`).
# AUTH_SECRET=replace-with-a-long-random-secret
# AUTH_URL — the dashboard's canonical public origin (scheme + host [+ base path]).
# Auth.js runs with trustHost:true, so in local dev it infers the origin from the
# request Host header. REQUIRED in production behind a proxy/load-balancer: set it
# to the real external origin so OAuth callback URLs and post-login redirects are
# built from a trusted value instead of a client-supplied (spoofable) Host header.
# AUTH_URL=https://engram.example.com
# Operator sign-in providers — set both id and secret to enable a provider.
# Callback URL: <dashboard origin>/api/auth/callback/<provider>.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# Comma-separated allow-list of operator emails permitted to sign in. Leave
# empty to allow any successful login (single-tenant / local only).
# ENGRAM_ADMIN_EMAILS=alice@example.com,bob@example.com
# Optional per-operator tenant binding (WP2 T9). Scopes each operator to specific
# data owners: "email:tenant1|tenant2;email2:*" ('*' = any). Unset ⇒ every
# operator manages every data owner. Enforced server-side on every tRPC procedure.
# ENGRAM_OPERATOR_TENANTS=alice@example.com:qp|ci-bot;bob@example.com:*
# Default data owner (userId) pre-selected in the navigator.
# ENGRAM_DEFAULT_USER_ID=qp
# Enables an email/password development sign-in. Never enable in production.
# ENGRAM_DASHBOARD_DEV_AUTH=true
