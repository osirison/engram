# ENGRAM Environment Configuration
# Copy this file to .env and update values as needed

# Node Environment
NODE_ENV=development

# Application
PORT=3000

# PostgreSQL Database
POSTGRES_DB=engram
POSTGRES_USER=engram
POSTGRES_PASSWORD=dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://engram:dev_password@localhost:5432/engram

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333

# Vector Store backend selection
VECTOR_BACKEND=qdrant            # or "pgvector"
VECTOR_DIMENSIONS=1536
# VECTOR_COLLECTION=memories

# Optional pgvector HNSW tuning (used when VECTOR_BACKEND=pgvector)
# PGVECTOR_HNSW_M=16
# PGVECTOR_HNSW_EF_CONSTRUCTION=64
# PGVECTOR_HNSW_EF_SEARCH=100

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# BullMQ Queue
BULL_QUEUE_NAME=engram-jobs

# Logging
LOG_LEVEL=debug
