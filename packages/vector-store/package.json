{
  "name": "@engram/vector-store",
  "version": "0.1.0",
  "type": "commonjs",
  "description": "Qdrant vector database client for ENGRAM",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "engram",
    "vector-store",
    "qdrant"
  ],
  "license": "MIT",
  "dependencies": {
    "@engram/database": "workspace:*",
