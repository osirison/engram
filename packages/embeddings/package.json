{
  "name": "@engram/embeddings",
  "version": "0.1.0",
  "description": "Embedding generation with OpenAI and Redis caching for ENGRAM memory system",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "backfill:ltm": "node dist/scripts/backfill-ltm-embeddings.js"
  },
  "keywords": [
    "engram",
    "embeddings",
    "openai",
    "vector",
    "memory"
  ],
  "license": "MIT",
  "devDependencies": {
    "@nestjs/testing": "^11.1.24",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.1",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@prisma/client": "^7.8.0",
    "openai": "^6.39.1",
    "reflect-metadata": "^0.2.2",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  }
}
