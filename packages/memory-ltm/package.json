{
  "name": "@engram/memory-ltm",
  "version": "0.1.0",
  "description": "Long-term memory module with PostgreSQL persistent storage for ENGRAM",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "engram",
    "memory",
    "long-term",
    "postgresql",
    "prisma",
    "persistence"
  ],
  "license": "MIT",
  "devDependencies": {
    "@nestjs/testing": "^11.1.24",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.1",
    "eslint": "^9.39.4",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@engram/config": "workspace:*",
    "@engram/database": "workspace:*",
    "@engram/embeddings": "workspace:*",
    "@engram/eval": "workspace:*",
    "@engram/memory-stm": "workspace:*",
    "@engram/vector-store": "workspace:*",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@prisma/client": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  }
}
