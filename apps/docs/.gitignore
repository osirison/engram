# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# build output
dist/
.astro/

# TypeDoc API reference is generated at astro build time (starlight-typedoc);
# it is always regenerated from source so it is never committed and cannot drift.
src/content/docs/reference/api/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (can opt-in for commiting if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
