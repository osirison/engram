{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "LOG_LEVEL",
    "PORT",
    "DEPLOYMENT_PROFILE",
    "DATABASE_URL",
    "WEB_DATABASE_URL",
    "REDIS_URL",
    "QDRANT_URL",
    "OPENAI_API_KEY",
    "EMBEDDING_PROVIDER",
    "VECTOR_BACKEND",
    "VECTOR_COLLECTION",
    "VECTOR_DIMENSIONS",
    "PGVECTOR_HNSW_M",
    "PGVECTOR_HNSW_EF_CONSTRUCTION",
    "PGVECTOR_HNSW_EF_SEARCH",
    "MEMORY_IMPORTANCE_HALF_LIFE_DAYS",
    "MEMORY_DUPLICATE_THRESHOLD",
    "PGVECTOR_TEST_URL",
    "LTM_QUOTA_TEST_URL",
    "MEMORY_VERSION_TEST_URL",
    "MEMORY_LINK_TEST_URL",
    "STM_SCAN_TEST_URL",
    "BACKFILL_BATCH_SIZE",
    "BACKFILL_MAX_BATCHES",
    "BACKFILL_DRY_RUN",
    "BACKFILL_RETRY_ATTEMPTS",
    "BACKFILL_RETRY_BASE_DELAY_MS",
    "ENGRAM_MCP_URL",
    "ENGRAM_API_KEY",
    "ENGRAM_ADMIN_EMAILS",
    "ENGRAM_OPERATOR_TENANTS",
    "ENGRAM_DEFAULT_USER_ID",
    "ENGRAM_DASHBOARD_DEV_AUTH",
    "AUTH_SECRET",
    "AUTH_URL",
    "AUTH_TRUST_HOST",
    "AUTH_GOOGLE_ID",
    "AUTH_GOOGLE_SECRET",
    "AUTH_GITHUB_ID",
    "AUTH_GITHUB_SECRET",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "NEXT_PUBLIC_DASHBOARD_NAME"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "eval": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "eval:gate": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
